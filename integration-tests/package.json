{
  "name": "integration-tests",
  "scripts": {
    "test": "vitest run",
    "test:secret-key": "RUN_WITH_SECRET_KEY=true vitest run",
    "test:tallinnnet": "TALLINNNET=true vitest run",
    "test:tallinnnet:shard": "TALLINNNET=true vitest run --passWithNoTests",
    "test:tallinnnet-secret-key": "RUN_TALLINNNET_WITH_SECRET_KEY=true vitest run",
    "test:shadownet": "SHADOWNET=true vitest run",
    "test:shadownet:shard": "SHADOWNET=true vitest run --passWithNoTests",
    "test:shadownet-secret-key": "RUN_SHADOWNET_WITH_SECRET_KEY=true vitest run",
    "test:weeklynet-secret-key": "RUN_WEEKLYNET_WITH_SECRET_KEY=true vitest run",
    "test:tezlinkshadownet-secret-key": "RUN_TEZLINKSHADOWNET_WITH_SECRET_KEY=true vitest run",
    "originate-known-contracts": "node -r ts-node/register originate-known-contracts.ts",
    "originate-known-contracts-and-run-test": "node -r ts-node/register originate-known-contracts.ts && vitest run",
    "rpc-hammer:inject": "node -r ts-node/register rpc-injection-hammer.ts"
  },
  "version": "24.2.0",
  "optionalDependencies": {
    "@ledgerhq/devices": "^8.8.0",
    "@ledgerhq/hw-transport": "^6.34.1",
    "@ledgerhq/hw-transport-node-hid": "6.30.0",
    "@ledgerhq/hw-transport-node-hid-noevents": "6.31.0"
  },
  "dependencies": {
    "@scure/bip39": "^2.0.1",
    "@taquito/contracts-library": "^24.2.0",
    "@taquito/core": "^24.2.0",
    "@taquito/http-utils": "^24.2.0",
    "@taquito/ledger-signer": "^24.2.0",
    "@taquito/local-forging": "^24.2.0",
    "@taquito/michel-codec": "^24.2.0",
    "@taquito/michelson-encoder": "^24.2.0",
    "@taquito/remote-signer": "^24.2.0",
    "@taquito/rpc": "^24.2.0",
    "@taquito/sapling": "^24.2.0",
    "@taquito/signer": "^24.2.0",
    "@taquito/taquito": "^24.2.0",
    "@taquito/timelock": "^24.2.0",
    "@taquito/tzip12": "^24.2.0",
    "@taquito/tzip16": "^24.2.0",
    "@taquito/utils": "^24.2.0",
    "bignumber.js": "^10.0.2",
    "blakejs": "^1.2.1",
    "rxjs": "^7.8.2"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "lint-staged": "^15.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
