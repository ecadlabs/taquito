{
  "name": "integration-tests",
  "scripts": {
    "test": "jest",
    "test:secret-key": "RUN_WITH_SECRET_KEY=true jest --runInBand",
    "test:tallinnnet": "TALLINNNET=true jest",
    "test:tallinnnet-secret-key": "RUN_TALLINNNET_WITH_SECRET_KEY=true jest --runInBand",
    "test:ghostnet": "GHOSTNET=true jest",
    "test:ghostnet-secret-key": "RUN_GHOSTNET_WITH_SECRET_KEY=true jest --runInBand",
    "test:shadownet": "SHADOWNET=true jest",
    "test:shadownet-secret-key": "RUN_SHADOWNET_WITH_SECRET_KEY=true jest --runInBand",
    "test:weeklynet-secret-key": "RUN_WEEKLYNET_WITH_SECRET_KEY=true jest --runInBand",
    "test:tezlinkshadownet-secret-key": "RUN_TEZLINKSHADOWNET_WITH_SECRET_KEY=true jest --runInBand",
    "originate-known-contracts": "node -r ts-node/register originate-known-contracts.ts",
    "originate-known-contracts-and-run-test": "node -r ts-node/register originate-known-contracts.ts && jest"
  },
  "version": "24.2.0",
  "optionalDependencies": {
    "@ledgerhq/devices": "^8.8.0",
    "@ledgerhq/hw-transport": "^6.31.15",
    "@ledgerhq/hw-transport-node-hid": "6.30.0",
    "@ledgerhq/hw-transport-node-hid-noevents": "6.31.0"
  },
  "dependencies": {
    "@taquito/contracts-library": "^24.2.0",
    "@taquito/core": "^24.2.0",
    "@taquito/http-utils": "^24.2.0",
    "@taquito/local-forging": "^24.2.0",
    "@taquito/michel-codec": "^24.2.0",
    "@taquito/michelson-encoder": "^24.2.0",
    "@taquito/remote-signer": "^24.2.0",
    "@taquito/rpc": "^24.2.0",
    "@taquito/sapling": "^24.2.0",
    "@taquito/signer": "^24.2.0",
    "@taquito/taquito": "^24.2.0",
    "@taquito/tzip12": "^24.2.0",
    "@taquito/tzip16": "^24.2.0",
    "@taquito/utils": "^24.2.0",
    "bignumber.js": "^9.1.2",
    "bip39": "3.1.0",
    "blakejs": "^1.2.1"
  },
  "private": true,
  "jest": {
    "transform": {
      ".(ts|tsx)": "ts-jest"
    },
    "testEnvironment": "node",
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx|js)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ],
    "testPathIgnorePatterns": [
      "./ledger-signer.spec.ts",
      "./ledger-signer-failing-tests.spec.ts"
    ],
    "reporters": [
      "default"
    ],
    "moduleNameMapper": {
      "^@taquito/core$": "<rootDir>/../packages/taquito-core/src/taquito-core.ts",
      "^@taquito/contracts-library$": "<rootDir>/../packages/taquito-contracts-library/src/contracts-library.ts",
      "^@taquito/http-utils$": "<rootDir>/../packages/taquito-http-utils/src/taquito-http-utils.ts",
      "^@taquito/local-forging$": "<rootDir>/../packages/taquito-local-forging/src/taquito-local-forging.ts",
      "^@taquito/michelson-encoder$": "<rootDir>/../packages/taquito-michelson-encoder/src/taquito-michelson-encoder.ts",
      "^@taquito/michel-codec$": "<rootDir>/../packages/taquito-michel-codec/src/taquito-michel-codec.ts",
      "^@taquito/rpc$": "<rootDir>/../packages/taquito-rpc/src/taquito-rpc.ts",
      "^@taquito/signer$": "<rootDir>/../packages/taquito-signer/src/taquito-signer.ts",
      "^@taquito/taquito$": "<rootDir>/../packages/taquito/src/taquito.ts",
      "^@taquito/timelock$": "<rootDir>/../packages/taquito-timelock/src/taquito-timelock.ts",
      "^@taquito/tzip12$": "<rootDir>/../packages/taquito-tzip12/src/taquito-tzip12.ts",
      "^@taquito/tzip16$": "<rootDir>/../packages/taquito-tzip16/src/taquito-tzip16.ts",
      "^@taquito/utils$": "<rootDir>/../packages/taquito-utils/src/taquito-utils.ts",
      "^@taquito/sapling$": "<rootDir>/../packages/taquito-sapling/src/taquito-sapling.ts",
      "^@taquito/ledger-signer$": "<rootDir>/../packages/taquito-ledger-signer/src/taquito-ledger-signer.ts",
      "^@taquito/remote-signer$": "<rootDir>/../packages/taquito-remote-signer/src/taquito-remote-signer.ts",
      "^@taquito/beacon-wallet$": "<rootDir>/../packages/taquito-beacon-wallet/src/taquito-beacon-wallet.ts",
      "^@taquito/wallet-connect$": "<rootDir>/../packages/taquito-wallet-connect/src/taquito-wallet-connect.ts"
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-config": "^29.7.0",
    "jest-retries": "^1.0.1",
    "jest-stare": "2.5.3",
    "lint-staged": "^15.2.7",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.5.4"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
