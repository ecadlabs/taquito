{

  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "skipLibCheck": true,
    "declarationDir": "./dist/types",
    "rootDir": "..",
    "outDir": "./dist/lib",
    "allowJs": true,
    "moduleResolution": "bundler",
    "target": "es6",
    "module": "commonjs",
    "lib": [
      "es2015",
      "es2016",
      "es2017",
      "dom"
    ]
  },
  "include": [
    "./**/*"
  ]
}
