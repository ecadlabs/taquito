{
  "name": "@taquito/taquito",
  "version": "24.2.0",
  "description": "TypeScript SDK for building wallets, dapps, and tooling on Tezos.",
  "keywords": [
    "taquito",
    "tezos",
    "typescript",
    "blockchain",
    "sdk",
    "wallet",
    "dapp"
  ],
  "main": "dist/taquito.umd.js",
  "unpkg": "dist/taquito.min.js",
  "module": "dist/taquito.es6.js",
  "typings": "dist/types/taquito.d.ts",
  "files": [
    "signature.json",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "ECAD Labs Inc <info@ecadlabs.com>",
  "contributors": [
    "Simon Boissonneault-Robert <simon@ecadlabs.com>",
    "Roxane Letourneau <roxane@ecadlabs.com>",
    "Davis Sawali <davis.sawali@ecadlabs.com>",
    "Jev Björsell (jevonearth)"
  ],
  "homepage": "https://taquito.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecadlabs/taquito.git"
  },
  "bugs": {
    "url": "https://github.com/ecadlabs/taquito/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --coverage --watch",
    "test:prod": "npm run lint && npm run test -- --no-cache",
    "lint": "eslint --ext .js,.ts .",
    "precommit": "lint-staged",
    "prebuild": "rimraf dist",
    "version-stamp": "node ./version-stamping.js",
    "build": "tsc --project ./tsconfig.prod.json --module commonjs && rollup -c rollup.config.ts --bundleConfigAsCjs",
    "build:release": "tsc --project ./tsconfig.prod.json --module commonjs && rollup -c rollup.config.ts --bundleConfigAsCjs && npm run build:web",
    "build:web": "webpack && node update-readme.js",
    "start": "rollup -c rollup.config.ts --bundleConfigAsCjs -w"
  },
  "lint-staged": {
    "{src,test}/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "jest": {
    "transform": {
      "^.+\\.(ts|tsx|js|mjs)$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "esModuleInterop": true,
            "allowJs": true
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@scure/bip39|@noble/hashes|@scure/base)/)"
    ],
    "testEnvironment": "node",
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx|js)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "moduleNameMapper": {
      "^@taquito/rpc$": "<rootDir>/../taquito-rpc/src/taquito-rpc.ts",
      "^@taquito/michelson-encoder$": "<rootDir>/../taquito-michelson-encoder/src/taquito-michelson-encoder.ts",
      "^@taquito/michel-codec$": "<rootDir>/../taquito-michel-codec/src/taquito-michel-codec.ts",
      "^@taquito/http-utils$": "<rootDir>/../taquito-http-utils/src/taquito-http-utils.ts",
      "^@taquito/utils$": "<rootDir>/../taquito-utils/src/taquito-utils.ts",
      "^@scure/bip39/wordlists/english.js$": "<rootDir>/../../node_modules/@scure/bip39/wordlists/english.js",
      "^@noble/hashes/blake2$": "<rootDir>/../../node_modules/@noble/hashes/blake2.js",
      "^@noble/hashes/hmac$": "<rootDir>/../../node_modules/@noble/hashes/hmac.js",
      "^@noble/hashes/sha2$": "<rootDir>/../../node_modules/@noble/hashes/sha2.js"
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,ts}"
    ]
  },
  "dependencies": {
    "@taquito/core": "^24.2.0",
    "@taquito/http-utils": "^24.2.0",
    "@taquito/local-forging": "^24.2.0",
    "@taquito/michel-codec": "^24.2.0",
    "@taquito/michelson-encoder": "^24.2.0",
    "@taquito/rpc": "^24.2.0",
    "@taquito/signer": "^24.2.0",
    "@taquito/utils": "^24.2.0",
    "bignumber.js": "^9.1.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@babel/types": "7.25.2",
    "@types/bluebird": "^3.5.42",
    "@types/estree": "^1.0.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "buffer": "^6.0.3",
    "colors": "^1.4.0",
    "coveralls": "^3.1.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-config": "^29.7.0",
    "lint-staged": "^15.2.7",
    "lodash.camelcase": "^4.3.0",
    "os-browserify": "^0.3.0",
    "prettier": "^3.3.3",
    "prompt": "^1.3.0",
    "replace-in-file": "^8.1.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.59.0",
    "rollup-plugin-json": "^4.0.0",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "rx-sandbox": "^2.0.5",
    "shelljs": "^0.8.5",
    "stream-browserify": "^3.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "ts-toolbelt": "^9.6.0",
    "typescript": "^5.9.3",
    "webpack": "^5.94.0",
    "webpack-assets-manifest": "^5.2.1",
    "webpack-cli": "^5.1.4",
    "webpack-subresource-integrity": "^5.1.0"
  },
  "gitHead": "551e35aeff7d6dcde1c7228npm install4238c0ed3c3aae77e"
}
