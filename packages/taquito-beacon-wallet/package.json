{
  "name": "@taquito/beacon-wallet",
  "version": "24.2.0",
  "description": "TZIP-10 Beacon wallet integration for Taquito dapps built on the Beacon SDK DAppClient.",
  "keywords": [
    "taquito",
    "tezos",
    "typescript",
    "blockchain",
    "wallet",
    "beacon"
  ],
  "main": "dist/taquito-beacon-wallet.umd.js",
  "module": "dist/taquito-beacon-wallet.es6.js",
  "typings": "dist/types/taquito-beacon-wallet.d.ts",
  "exports": {
    ".": {
      "import": "./dist/taquito-beacon-wallet.es6.js",
      "require": "./dist/taquito-beacon-wallet.umd.js",
      "types": "./dist/types/taquito-beacon-wallet.d.ts"
    },
    "./types": {
      "import": "./dist/beacon-types.es6.js",
      "require": "./dist/beacon-types.umd.js",
      "types": "./dist/types/beacon-types.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "signature.json",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "ECAD Labs Inc <info@ecadlabs.com>",
  "contributors": [
    "Roxane Letourneau <roxane@ecadlabs.com>",
    "Davis Sawali <davis.sawali@ecadlabs.com>",
    "Jev Björsell (jevonearth)",
    "Simon Boissonneault-Robert <simon@ecadlabs.com>"
  ],
  "homepage": "https://taquito.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecadlabs/taquito.git"
  },
  "bugs": {
    "url": "https://github.com/ecadlabs/taquito/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --coverage --watch",
    "test:prod": "npm run lint && npm run test -- --no-cache",
    "lint": "eslint --ext .js,.ts .",
    "precommit": "lint-staged",
    "prebuild": "rimraf dist",
    "version-stamp": "node ../taquito/version-stamping.js",
    "build": "tsc --project ./tsconfig.prod.json --module commonjs && rollup -c rollup.config.ts --bundleConfigAsCjs",
    "start": "rollup -c rollup.config.ts --bundleConfigAsCjs -w",
    "build-webpack": "webpack --progress --color"
  },
  "lint-staged": {
    "{src,test}/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "jest": {
    "transform": {
      ".(ts|tsx)": [
        "ts-jest",
        {
          "useESM": true,
          "allowJs": true,
          "tsconfig": {
            "allowJs": true,
            "module": "es2020"
          }
        }
      ],
      ".(js|jsx|mjs)": [
        "ts-jest",
        {
          "useESM": true,
          "allowJs": true,
          "tsconfig": {
            "allowJs": true,
            "module": "es2020"
          }
        }
      ],
      "node_modules/@noble/hashes/.+\\.(j|t)sx?$": "ts-jest"
    },
    "testEnvironment": "node",
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx|js)$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "mjs"
    ],
    "moduleNameMapper": {
      "^@taquito/taquito$": "<rootDir>/../taquito/src/taquito.ts",
      "^@taquito/utils$": "<rootDir>/../taquito-utils/src/taquito-utils.ts",
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^@scure/bip39/wordlists/english.js$": "<rootDir>/../../node_modules/@scure/bip39/wordlists/english.js",
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^@noble/hashes/blake2$": "<rootDir>/../../node_modules/@noble/hashes/blake2.js",
      "^@stablelib/blake2b$": "<rootDir>/../../node_modules/@stablelib/blake2b/lib/blake2b.js",
      "^@noble/hashes/hmac$": "<rootDir>/../../node_modules/@noble/hashes/hmac.js",
      "^@noble/hashes/sha2$": "<rootDir>/../../node_modules/@noble/hashes/sha2.js",
      "^@noble/hashes/pbkdf2$": "<rootDir>/../../node_modules/@noble/hashes/pbkdf2.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(@ecadlabs|@stablelib|@scure/bip39|@noble/hashes|@scure/base)/.*)"
    ],
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx",
      ".mts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,ts}"
    ]
  },
  "dependencies": {
    "@ecadlabs/beacon-dapp": "^4.8.1-ecad",
    "@ecadlabs/beacon-types": "^4.8.1-ecad",
    "@taquito/core": "^24.2.0",
    "@taquito/taquito": "^24.2.0",
    "crypto-browserify": "^3.12.1",
    "util": "^0.12.5",
    "@stablelib/ed25519": "^2.0.2"
  },
  "devDependencies": {
    "@ecadlabs/beacon-transport-postmessage": "^4.8.1-ecad",
    "@ecadlabs/beacon-ui": "^4.8.1-ecad",
    "@types/bluebird": "^3.5.42",
    "@types/chrome": "0.0.269",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "colors": "^1.4.0",
    "coveralls": "^3.1.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.7.0",
    "jest-config": "^29.7.0",
    "lint-staged": "^15.2.7",
    "lodash.camelcase": "^4.3.0",
    "prettier": "^3.3.3",
    "prompt": "^1.3.0",
    "replace-in-file": "^8.1.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.59.0",
    "rollup-plugin-json": "^4.0.0",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "shelljs": "^0.8.5",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "ts-toolbelt": "^9.6.0",
    "typescript": "^5.9.3",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  },
  "gitHead": "551e35aeff7d6dcde1c72284238c0ed3c3aae77e"
}
