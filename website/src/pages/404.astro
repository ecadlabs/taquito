---
import MainLayout from '../layouts/MainLayout.astro';
import { DEFAULT_VERSION } from '../config/versions.mjs';
---

<MainLayout title="Page Not Found" description="The page you're looking for doesn't exist." noindex={true}>
  <div class="flex flex-col items-center justify-center py-24 px-6 text-center">
    <h1 class="text-6xl font-bold text-primary mb-4">404</h1>
    <h2 class="text-2xl font-semibold text-text-secondary mb-6">Page Not Found</h2>
    <p class="text-lg text-text-secondary/70 mb-8 max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href="/"
        class="bg-primary text-white hover:bg-primary/90 transition-colors duration-150 px-6 py-3 rounded-full font-medium"
      >
        Go to Homepage
      </a>
      <a
        href={`/docs/${DEFAULT_VERSION}/quick_start`}
        class="border-2 border-primary text-primary hover:bg-primary/10 transition-colors duration-150 px-6 py-3 rounded-full font-medium"
      >
        View Documentation
      </a>
    </div>

    <div class="mt-12 text-sm text-text-secondary/60">
      <p>Looking for older documentation versions?</p>
      <p class="mt-2">
        Try adding a version number to the URL, e.g.,{' '}
        <code class="bg-gray-100 px-2 py-1 rounded">/docs/{DEFAULT_VERSION}/quick_start</code>
      </p>
    </div>
  </div>
</MainLayout>

<style>
  /* Ensure 404 page is not indexed */
  :global(head) {
    /* noindex is already in MainLayout for 404 status pages */
  }
</style>
